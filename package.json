{
  "name": "hbdr-website",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "npx @tailwindcss/cli -i src/styles/main.css -o public/assets/styles.css --watch & NODE_ENV=development tsx server/index.ts",
    "css:build": "npx @tailwindcss/cli -i src/styles/main.css -o public/assets/styles.css --minify",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit",
    "deploy": "npm run css:build && wrangler deploy"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260305.1",
    "hono": "^4.12.5",
    "wrangler": "^4.71.0",
    "zod": "^4.3.6",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.11",
    "@tailwindcss/cli": "^4.2.1",
    "@types/node": "^22.15.0",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
